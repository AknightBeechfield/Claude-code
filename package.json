{
  "name": "beechfield-website",
  "version": "1.0.0",
  "description": "Beechfield Original Headwear — brand site with product catalogue, stock checker, and distributor integration",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "import-products": "node scripts/import-product-data.js",
    "extract-images": "node scripts/extract-images.js",
    "seed-stock": "node scripts/seed-stock-data.js",
    "generate-pages": "node scripts/generate-products.js",
    "data": "npm run import-products && npm run extract-images && npm run seed-stock",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "beechfield",
    "headwear",
    "product-catalogue",
    "decoration"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
